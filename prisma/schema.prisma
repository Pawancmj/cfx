generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model contact_submissions {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  email      String   @db.VarChar(255)
  industry   String   @db.VarChar(100)
  message    String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
}

model internship_applications {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(255)
  email        String   @db.VarChar(255)
  phone        String   @db.VarChar(50)
  university   String   @db.VarChar(255)
  degree       String   @db.VarChar(255)
  linkedin_url String?  @db.VarChar(255)
  resume_url   String   @db.VarChar(255)
  role         String   @db.VarChar(100)
  created_at   DateTime @default(now()) @db.Timestamp(0)
}

model InternshipVacancy {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  description  String   @db.Text
  location     String   @db.VarChar(100)
  type         String   @db.VarChar(50) // Full-time, Internship, etc.
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now()) @db.Timestamp(0)
  updated_at   DateTime @updatedAt @db.Timestamp(0)

  @@map("internship_vacancies")
}
